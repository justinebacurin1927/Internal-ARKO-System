// ARKO — internal collaboration platform schema.
// Core idea: shared models. One Task model (three views), one polymorphic
// Comment, one polymorphic Attachment. See ARKO-Scoping.docx.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum TaskStatus {
  BACKLOG
  DESIGN
  DEV
  TESTING
  DONE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(MEMBER)
  createdAt    DateTime @default(now())

  assignedTasks Task[]         @relation("assignee")
  authoredDocs  Document[]     @relation("docAuthor")
  comments      Comment[]
  uploads       Attachment[]
  notifications Notification[]
}

model Milestone {
  id          String   @id @default(cuid())
  name        String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  tasks       Task[]
  documents   Document[]
  storyboards Storyboard[]
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(BACKLOG)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  milestoneId String

  assignee   User?   @relation("assignee", fields: [assigneeId], references: [id])
  assigneeId String?

  comments    Comment[]
  attachments Attachment[]

  @@index([milestoneId])
  @@index([status])
}

model Document {
  id          String   @id @default(cuid())
  title       String
  contentMd   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author   User   @relation("docAuthor", fields: [authorId], references: [id])
  authorId String

  milestone   Milestone? @relation(fields: [milestoneId], references: [id])
  milestoneId String?

  comments    Comment[]
  attachments Attachment[]
}

// Phase 2 — modeled now so the polymorphic relations are stable.
model Storyboard {
  id          String   @id @default(cuid())
  title       String
  narrativeMd String   @default("")
  excalidraw  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId String

  milestone   Milestone? @relation(fields: [milestoneId], references: [id])
  milestoneId String?

  comments    Comment[]
  attachments Attachment[]
}

// Polymorphic via explicit nullable FKs. Exactly one of the three is set;
// enforced at the app layer (see lib/polymorphic.ts).
model Comment {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  task         Task?       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId       String?
  document     Document?   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId   String?
  storyboard   Storyboard? @relation(fields: [storyboardId], references: [id], onDelete: Cascade)
  storyboardId String?

  notifications Notification[]

  @@index([taskId])
  @@index([documentId])
  @@index([storyboardId])
}

model Attachment {
  id        String   @id @default(cuid())
  fileName  String
  s3Key     String   @unique
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  uploader   User   @relation(fields: [uploaderId], references: [id])
  uploaderId String

  task         Task?       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId       String?
  document     Document?   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId   String?
  storyboard   Storyboard? @relation(fields: [storyboardId], references: [id], onDelete: Cascade)
  storyboardId String?

  @@index([taskId])
  @@index([documentId])
  @@index([storyboardId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String // "mention"
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId String?

  @@index([userId, read])
}
