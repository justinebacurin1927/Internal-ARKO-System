{
  "name": "arko",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "pnpm --filter @arko/db prisma generate",
    "db:push": "pnpm --filter @arko/db prisma db push",
    "db:migrate": "pnpm --filter @arko/db prisma migrate dev",
    "db:studio": "pnpm --filter @arko/db prisma studio",
    "typecheck": "tsc --noEmit",
    "cleanup": "bash scripts/cleanup.sh"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
